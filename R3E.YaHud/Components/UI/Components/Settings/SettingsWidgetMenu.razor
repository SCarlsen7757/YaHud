@using R3E.YaHud.Components.Widget.Core
@implements IDisposable

<div class="widget-menu-wrapper">
    <button class="btn ghost" @onclick="() => menuOpen = !menuOpen" @onclick:stopPropagation>
        <Icon Name="elipsis-vertical" />
    </button>

    @if (menuOpen)
    {
        <div class="widget-menu">
            <ul>
                <li class="menu-item" @onclick="() => Widget.ResetPosition()">Reset Position</li>
                <li class="menu-item" @onclick="() => Widget.ResetScale()">Reset Scale</li>
            </ul>
        </div>
    }
</div>

@code {
    [Parameter] public IWidget Widget { get; set; } = null!;
    [CascadingParameter] public SettingPanelEvents? MasterPanelEvents { get; set; }

    private bool menuOpen = false;
    private Action? bodyClickedHandler;

    protected override void OnInitialized()
    {
        if (MasterPanelEvents != null)
        {
            this.bodyClickedHandler = () =>
            {
            menuOpen = false;
            InvokeAsync(StateHasChanged);
        };
            MasterPanelEvents.BodyClicked += this.bodyClickedHandler;
        }
    }
    public void Dispose()
    {
        if (MasterPanelEvents != null && bodyClickedHandler != null)
        {
            MasterPanelEvents.BodyClicked -= bodyClickedHandler;
        }
    }
}
